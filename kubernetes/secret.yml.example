# Crie os secrets diretamente no cluster (NÃO commite valores reais):
#
# kubectl create secret generic postgres-secret \
#   --from-literal=POSTGRES_USER=admin \
#   --from-literal=POSTGRES_PASSWORD=SuaSenha123 \
#   -n staging
#
# kubectl create secret generic app-secret \
#   --from-literal=SPRING_DATASOURCE_USERNAME=admin \
#   --from-literal=SPRING_DATASOURCE_PASSWORD=SuaSenha123 \
#   -n staging
#
# Repita com -n production
